# Application Configuration
NODE_ENV=development
PORT=4000
API_PREFIX=api
APP_NAME="NestApp Service"
APP_TIMEZONE = "UTC";


# Database Configuration (MySQL)
DB_DRIVER=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
